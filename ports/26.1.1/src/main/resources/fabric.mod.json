{
  "schemaVersion": 1,
  "id": "inventory-organizer",
  "version": "1.5.2",
  "name": "Inventory Organizer",
  "description": "A Minecraft mod that organizes your inventory with a button below the crafting table",
  "authors": ["Zefryxis"],
  "contact": {
    "homepage": "https://github.com/Zefryxis/InOr",
    "sources": "https://github.com/Zefryxis/InOr"
  },
  "license": "MIT",
  "icon": "assets/inventory-organizer/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": ["com.example.inventoryorganizer.InventoryOrganizerClient"],
    "main": ["com.example.inventoryorganizer.InventoryOrganizer"],
    "modmenu": ["com.example.inventoryorganizer.config.ModMenuIntegration"]
  },
  "mixins": ["inventory-organizer.mixins.json", "inventory-organizer.crafting.mixins.json"],
  "depends": {
    "fabricloader": ">=0.19",
    "fabric-api": "*",
    "minecraft": "~26.1.1"
  }
}
